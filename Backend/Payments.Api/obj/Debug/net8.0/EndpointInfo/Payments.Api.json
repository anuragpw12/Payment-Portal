        "type": "object",
        "properties": {
          "amount": {
            "maximum": 999999999999999.9999,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "currency": {
            "maxLength": 10,
            "minLength": 3,
            "type": "string"
          },
          "clientRequestId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "CreatePaymentResponseDto": {
        "required": [
          "payment"
        ],
        "type": "object",
        "properties": {
          "payment": {
            "$ref": "#/components/schemas/PaymentDto"
          },
          "isDuplicate": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "PaymentDto": {
        "type": "object",
